# Application port
PORT=3001

# Telegram Bot API token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional downloads directory; defaults to ./downloads
DOWNLOADS_PATH=./downloads

# Maximum age in hours before temporary downloads are cleaned up
FILE_MAX_AGE_HOURS=24

# CORS origin for API access
CORS_ORIGIN=*

# Environment mode
NODE_ENV=development
